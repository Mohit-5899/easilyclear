# Copy to .env and fill in values. .env is gitignored.

APP_ENV=dev

# JSON array of allowed CORS origins (frontend dev servers)
CORS_ALLOW_ORIGINS=["http://localhost:3001","http://127.0.0.1:3001"]

# LLM provider switch. Options: openrouter | ollama | mock
# - mock     → deterministic fake responses (no key required), use for early dev
# - openrouter → hosted Gemma 4 via OpenRouter API (build + dev phase)
# - ollama   → local Gemma 4 via Ollama (Day 26+, offline demo)
LLM_PROVIDER=mock

# OpenRouter — required when LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://github.com/gemma-tutor
OPENROUTER_APP_NAME=Gemma Tutor

# Ollama — used when LLM_PROVIDER=ollama (Day 26+)
OLLAMA_BASE_URL=http://localhost:11434

# Gemma 4 via OpenRouter. Confirmed available 2026-04-15.
# Free tier (`:free` suffix): $0, light rate limits — fine for dev.
# Paid tier (no suffix): ~$0.08/$0.35 per M tokens in/out.
# Other options: google/gemma-4-31b-it:free (31B Dense, 256K ctx)
MODEL_ANSWER=google/gemma-4-26b-a4b-it:free
MODEL_RETRIEVAL=google/gemma-4-26b-a4b-it:free

REQUEST_TIMEOUT_SECONDS=60
